@* Pas de @model car on utilise ViewBag *@
@{
    ViewData["Title"] = "Détail Actif";
    var actif = ViewBag.Actif as web_portefeuille.Models.Actif;
    var donnees = ViewBag.Donnees as List<web_portefeuille.Models.Donneeboursiere>
                  ?? new List<web_portefeuille.Models.Donneeboursiere>();
}

<style>
    body { background-color: #1a2744; color: white; }

    .page-header {
        padding: 40px 40px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .btn-retour {
        background-color: #243558;
        color: #a0b0c8;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    .btn-retour:hover {
        background-color: #2e4270;
        color: white;
        text-decoration: none;
    }

    .titre-actif h1 { font-size: 2rem; margin: 0; }
    .titre-actif .sym {
        color: #00c878;
        font-size: 1rem;
        font-weight: bold;
    }

    /* ── Badge ── */
    .badge {
        display: inline-block;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: bold;
    }
    .badge-action { background-color: rgba(0,120,255,0.2); color: #4da6ff; }
    .badge-crypto { background-color: rgba(255,165,0,0.2); color: #ffaa33; }

    /* ── Cartes de stats ── */
    .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        padding: 20px 40px;
    }

    .stat-carte {
        background-color: #243558;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
    }
    .stat-carte .label {
        color: #a0b0c8;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }
    .stat-carte .valeur {
        font-size: 1.4rem;
        font-weight: bold;
        color: #00c878;
    }

    /* ── Graphique ── */
    .graphique-container {
        background-color: #243558;
        border-radius: 12px;
        padding: 30px;
        margin: 0 40px 40px;
    }
    .graphique-container h2 {
        font-size: 1.1rem;
        color: #a0b0c8;
        margin-bottom: 16px;
    }

    /* ── Boutons de période ── */
    .periode-btns {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
        flex-wrap: wrap;
        align-items: center;
    }
    .periode-btn {
        background-color: #1a2744;
        color: #a0b0c8;
        border: 1px solid #2e4270;
        padding: 6px 16px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s;
        font-weight: 500;
    }
    .periode-btn:hover {
        background-color: rgba(0, 200, 120, 0.15);
        color: #00c878;
        border-color: #00c878;
    }
    .periode-btn.actif {
        background-color: #00c878;
        color: #1a2744;
        border-color: #00c878;
        font-weight: bold;
    }
    .reset-zoom-btn {
        background-color: #1a2744;
        color: #a0b0c8;
        border: 1px solid #2e4270;
        padding: 6px 14px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.85rem;
        margin-left: auto;
        transition: all 0.2s;
    }
    .reset-zoom-btn:hover {
        background-color: #2e4270;
        color: white;
    }

    /* ── Info zoom ── */
    .zoom-info {
        font-size: 0.78rem;
        color: #5a6a80;
        margin-top: 10px;
        text-align: right;
    }

    /* ── Tableau des données ── */
    .tableau-container {
        background-color: #243558;
        border-radius: 12px;
        padding: 30px;
        margin: 0 40px 60px;
    }
    .tableau-container h2 {
        font-size: 1.1rem;
        margin-bottom: 20px;
    }

    table { width: 100%; border-collapse: collapse; }
    thead th {
        color: #a0b0c8;
        font-size: 0.85rem;
        text-align: left;
        padding: 10px;
        border-bottom: 1px solid #1a2744;
    }
    tbody td {
        padding: 12px 10px;
        border-bottom: 1px solid #1a2744;
        font-size: 0.9rem;
    }
    tbody tr:hover { background-color: rgba(255,255,255,0.03); }

    .prix-valeur { color: #00c878; font-weight: bold; }

    /* ── Message vide ── */
    .vide {
        text-align: center;
        color: #a0b0c8;
        padding: 40px;
    }

    /* ── Erreur ── */
    .alerte-erreur {
        background-color: rgba(255,77,77,0.1);
        border: 1px solid #ff4d4d;
        color: #ff4d4d;
        padding: 15px 30px;
        border-radius: 10px;
        margin: 20px 40px;
        text-align: center;
    }
</style>

@* ── Erreur ── *@
@if (ViewBag.Erreur != null)
{
    <div class="alerte-erreur">⚠️ @ViewBag.Erreur</div>
}

@if (actif != null)
{
    @* ── En-tête ── *@
    <div class="page-header">
        <a class="btn-retour" asp-controller="Actifs" asp-action="Index">
            ← Retour
        </a>
        <div class="titre-actif">
            <span class="badge @(actif.Type == "Crypto" ? "badge-crypto" : "badge-action")">
                @(actif.Type == "Crypto" ? "₿ Crypto" : "📈 Action")
            </span>
            <h1>@actif.Nom</h1>
            <div class="sym">@actif.Symbole · @actif.Secteur</div>
        </div>
    </div>

    @* ── Cartes de stats (dernière donnée) ── *@
    @if (donnees.Any())
    {
        var derniere = donnees.First(); @* Les données sont triées par date DESC *@
        var premiere = donnees.Last();
        var variation = premiere.Cloture > 0
            ? ((derniere.Cloture - premiere.Cloture) / premiere.Cloture) * 100
            : 0;

        <div class="stats">
            <div class="stat-carte">
                <div class="label">Prix actuel</div>
                <div class="valeur">@derniere.Cloture.ToString("F2") $</div>
            </div>
            <div class="stat-carte">
                <div class="label">Volume</div>
                <div class="valeur">@derniere.Volume.ToString("N0")</div>
            </div>
            <div class="stat-carte">
                <div class="label">Variation (@donnees.Count j)</div>
                <div class="valeur" style="color: @(variation >= 0 ? "#00c878" : "#ff4d4d")">
                    @(variation >= 0 ? "+" : "")@variation.ToString("F2")%
                </div>
            </div>
            <div class="stat-carte">
                <div class="label">Dernière MAJ</div>
                <div class="valeur" style="font-size:1rem">
                    @derniere.Date.ToString("dd/MM/yyyy")
                </div>
            </div>
        </div>

        @* ── Graphique Chart.js ── *@
        <div class="graphique-container">
            <h2>📈 Évolution du prix de clôture</h2>

            @* ── Boutons de période ── *@
            <div class="periode-btns">
                <button class="periode-btn" onclick="filtrerPeriode(7, this)">7J</button>
                <button class="periode-btn" onclick="filtrerPeriode(30, this)">1M</button>
                <button class="periode-btn" onclick="filtrerPeriode(90, this)">3M</button>
                <button class="periode-btn" onclick="filtrerPeriode(180, this)">6M</button>
                <button class="periode-btn" onclick="filtrerPeriode(365, this)">1A</button>
                <button class="periode-btn" onclick="filtrerPeriode(730, this)">2A</button>
                <button class="periode-btn actif" onclick="toutAfficher(this)">Tout</button>
                <button class="reset-zoom-btn" onclick="chart.resetZoom()">🔍 Reset zoom</button>
            </div>

            <canvas id="graphique" height="80"></canvas>
            <div class="zoom-info">🖱️ Molette pour zoomer · Clic + glisser pour naviguer</div>
        </div>

        @* ── Tableau des données brutes ── *@
        <div class="tableau-container">
            <h2>📋 Historique des données (@donnees.Count entrées)</h2>
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Prix de clôture</th>
                        <th>Volume</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in donnees)
                    {
                        <tr>
                            <td>@d.Date.ToString("dd/MM/yyyy")</td>
                            <td class="prix-valeur">@d.Cloture.ToString("F2") $</td>
                            <td>@d.Volume.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="vide">
            <p>Aucune donnée boursière disponible pour cet actif.</p>
            <p style="color:#a0b0c8; font-size:0.9rem">
                Faites un fetch depuis l'API :
                POST /api/donneeboursieres/fetch-all
            </p>
        </div>
    }
}

@* ── Scripts Chart.js + Zoom ── *@
@section Scripts {
    @* Chart.js doit être chargé AVANT le plugin zoom *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>

    <script>
        
        // DONNÉES : injectées depuis Razor (C#) vers JavaScript
        // Les données arrivent triées DESC (plus récent en premier)
        // On les inverse (.Reverse()) pour avoir l'ordre chronologique
        
        const toutesLesDonnees = {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                donnees.AsEnumerable().Reverse()
                       .Select(d => d.Date.ToString("dd/MM/yyyy"))
                       .ToList()
            )),
            prix: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                donnees.AsEnumerable().Reverse()
                       .Select(d => Math.Round(d.Cloture, 2))
                       .ToList()
            ))
        };

      
        // CRÉATION DU GRAPHIQUE
       
        const ctx = document.getElementById('graphique').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: toutesLesDonnees.labels,
                datasets: [{
                    label: 'Prix de clôture ($)',
                    data: toutesLesDonnees.prix,
                    borderColor: '#00c878',
                    backgroundColor: 'rgba(0, 200, 120, 0.08)',
                    borderWidth: 2,
                    // pointRadius 0 = points invisibles par défaut (plus lisible avec 750+ points)
                    pointRadius: 0,
                    // pointHoverRadius = point visible au survol
                    pointHoverRadius: 5,
                    pointHoverBackgroundColor: '#00c878',
                    pointHoverBorderColor: '#fff',
                    pointHoverBorderWidth: 2,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                // interaction : comment le tooltip réagit à la souris
                interaction: {
                    mode: 'index',       // Affiche le tooltip pour toute la colonne verticale
                    intersect: false     // Pas besoin d'être exactement sur un point
                },
                plugins: {
                    legend: {
                        labels: { color: '#a0b0c8' }
                    },
                    // ── Tooltip personnalisé ──
                    tooltip: {
                        backgroundColor: '#162035',
                        titleColor: '#a0b0c8',
                        bodyColor: '#00c878',
                        borderColor: '#00c878',
                        borderWidth: 1,
                        padding: 12,
                        callbacks: {
                            // Titre du tooltip = la date
                            title: items => `📅 ${items[0].label}`,
                            // Corps du tooltip = le prix formaté
                            label: item => ` Prix : ${item.parsed.y.toFixed(2)} $`
                        }
                    },
                    // ── Plugin zoom/pan ──
                    zoom: {
                        pan: {
                            enabled: true,   // Clic + glisser pour naviguer dans le temps
                            mode: 'x'        // Uniquement horizontal (pas vertical)
                        },
                        zoom: {
                            wheel: {
                                enabled: true,    // Molette de la souris = zoom
                                speed: 0.1        // Vitesse du zoom (0.1 = doux)
                            },
                            pinch: {
                                enabled: true     // Pinch sur mobile = zoom
                            },
                            mode: 'x'             // Uniquement horizontal
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: {
                            color: '#a0b0c8',
                            maxTicksLimit: 12,    // Maximum 12 étiquettes visibles sur l'axe X
                            maxRotation: 0        // Texte horizontal (pas de rotation)
                        },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    },
                    y: {
                        ticks: {
                            color: '#a0b0c8',
                            // Formate les valeurs Y avec le symbole $
                            callback: val => val.toLocaleString('fr-FR') + ' $'
                        },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    }
                }
            }
        });

        
        // FILTRE PAR PÉRIODE
        // Garde seulement les données des N derniers jours
        
        function filtrerPeriode(jours, bouton) {
            // 1. Met à jour le style des boutons (enlève .actif de tous, ajoute au cliqué)
            document.querySelectorAll('.periode-btn').forEach(b => b.classList.remove('actif'));
            bouton.classList.add('actif');

            // 2. Calcule la date de début (aujourd'hui - N jours)
            const dateDebut = new Date();
            dateDebut.setDate(dateDebut.getDate() - jours);

            // 3. Filtre les données : garde seulement celles >= dateDebut
            const filtered = toutesLesDonnees.labels.reduce((acc, label, i) => {
                // Convertit le format "dd/MM/yyyy" en objet Date JavaScript
                const parts = label.split('/');
                const date = new Date(parts[2], parts[1] - 1, parts[0]);

                if (date >= dateDebut) {
                    acc.labels.push(label);
                    acc.prix.push(toutesLesDonnees.prix[i]);
                }
                return acc;
            }, { labels: [], prix: [] });

            // 4. Met à jour le graphique avec les données filtrées
            chart.data.labels = filtered.labels;
            chart.data.datasets[0].data = filtered.prix;
            chart.resetZoom();  // Reset le zoom avant d'appliquer la nouvelle période
            chart.update();
        }

        
        // TOUT AFFICHER
        // Remet toutes les données originales
       
        function toutAfficher(bouton) {
            document.querySelectorAll('.periode-btn').forEach(b => b.classList.remove('actif'));
            bouton.classList.add('actif');

            // Remet les données complètes
            chart.data.labels = toutesLesDonnees.labels;
            chart.data.datasets[0].data = toutesLesDonnees.prix;
            chart.resetZoom();
            chart.update();
        }
    </script>
}
